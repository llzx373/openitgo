{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug openitgo-app",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["run", "-p", "openitgo-app"]
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {}
    },
    {
      "name": "Debug openitgo-app (release)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["run", "--release", "-p", "openitgo-app"]
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {}
    },
    {
      "name": "Attach to openitgo-app",
      "type": "lldb",
      "request": "attach",
      "pid": "${command:pickMyProcess}"
    }
  ]
}
